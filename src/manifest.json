{
    "manifest_version": 3,
    "name": "ReDD 2FA: Phone-Free Authentication",
    "description": "Minimalist, local-only TOTP authenticator. Secure, encrypted, and simple.",
    "version": "1.1.0",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png"
        }
    },
    "background": {
        "scripts": [
            "background.js"
        ],
        "service_worker": "background.js"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "permissions": [
        "storage",
        "tabs"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "redd-2fa@reddfocus.org",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}